{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kwawingu/inquiry-form",
  "title": "KwaWingu Inquiry Form",
  "category": "widgets",
  "icon": "email",
  "description": "Send an inquiry to the operator directly from your website.",
  "textdomain": "kwawingu-tours",
  "attributes": {
    "heading": { "type": "string", "default": "Send us an inquiry" },
    "tourSlug": { "type": "string", "default": "" }
  },
  "supports": { "html": false },
  "viewScript": "file:./view.js",
  "render": "file:./render.php",
  "editorScript": "file:../../build/inquiry-form/index.js"
}
